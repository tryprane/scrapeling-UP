# OpenAI OAuth proxy / official OpenAI API
OPENAI_API_KEY=local-proxy
OPENAI_BASE_URL=http://127.0.0.1:10531/v1
OPENAI_MODEL=gpt-5.1
OPENAI_ANALYZER_MODEL=gpt-5.1

# Codex OAuth SDK (Python 3.11+)
CODEX_OAUTH_ENABLED=false
CODEX_MODEL=gpt-5.3-codex
LLM_PROVIDER=auto

# ── Groq AI ────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_ANALYZER_MODEL=llama-3.3-70b-versatile

# ── Polling ────────────────────────────────────────
# How often to check for new jobs (in minutes)
POLL_INTERVAL_MINUTES=15

# Delay between AI calls inside a cycle (in seconds)
AI_CALL_DELAY_SECONDS=60

# Browser mode for browser-based contact discovery flows.
# Set true for fully headless runs, or false when using a visible browser
# or a virtual display like Xvfb on a VPS.
HEADLESS=false

# Number of background outreach workers. Keep this at 1 if you want MailTester
# to run one browser verification at a time.
OUTREACH_ASYNC_WORKERS=1

# ── Upwork Search URLs ─────────────────────────────
# Comma-separated list of public Upwork search URLs
# Tip: go to upwork.com/nx/search/jobs, apply your filters, copy the URL
UPWORK_SEARCH_URLS=https://www.upwork.com/nx/search/jobs/?category2_uid=531770282580668418&sort=recency&per_page=20,https://www.upwork.com/nx/search/jobs/?q=web+development&sort=recency&per_page=20,https://www.upwork.com/nx/search/jobs/?q=automation&sort=recency&per_page=20

# ── Notifications ──────────────────────────────────
# Enable desktop toast notifications (true/false)
ENABLE_NOTIFICATIONS=true

# Outbound email API
PRANE_BASE_URL=https://prane.one
PRANE_API_KEY=your_outbound_live_api_key_here

# Email verification
EMAIL_VERIFIER_PROVIDER=local
QUICKEMAILVERIFICATION_API_KEYS=
QUICKEMAILVERIFICATION_TIMEOUT_SECONDS=30
MAILTESTER_VERIFIER_VISIBLE=true
MAILTESTER_VERIFIER_URL=https://mailtester.ninja/email-verifier/
MAILTESTER_VERIFIER_PAGE_TIMEOUT_MS=30000
MAILTESTER_VERIFIER_WAIT_SECONDS=90
MAILTESTER_VERIFIER_BATCH_SIZE=1
