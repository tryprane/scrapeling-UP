# ── Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Polling ────────────────────────────────────────
# How often to check for new jobs (in minutes)
POLL_INTERVAL_MINUTES=5

# ── Upwork Search URLs ─────────────────────────────
# Comma-separated list of public Upwork search URLs
# Tip: go to upwork.com/nx/search/jobs, apply your filters, copy the URL
UPWORK_SEARCH_URLS=https://www.upwork.com/nx/search/jobs/?category2_uid=531770282580668418&sort=recency&per_page=20

# ── Browser ────────────────────────────────────────
# Set to true to run headless (invisible). MUST be true on a VPS.
HEADLESS=true

# ── Notifications ──────────────────────────────────
# Enable desktop toast notifications. Set to false on a VPS (no desktop).
ENABLE_NOTIFICATIONS=false
